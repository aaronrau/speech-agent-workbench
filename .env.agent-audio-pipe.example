# Agent Audio Pipe supplies ASR, so keep microphone/STT capture disabled here.
VOICE_DISABLE_STT=1

# Keep the persistent API listener running; voice termination is enabled by
# default for microphone-driven workbenches.
VOICE_AUTO_ENABLE_TERMINATE_COMMANDS=0

# Keep the API and receiver authentication aligned with Agent Audio Pipe.
VOICE_API_ENABLED=1
VOICE_API_PORT=8787
VOICE_API_TOKEN=local-secret
VOICE_TMUX_SUMMARY_WEBHOOK_URL=http://127.0.0.1:8788/workbench/summary
VOICE_TMUX_SUMMARY_WEBHOOK_TOKEN=summary-secret

# Keep the API listener and both console logs in the pane-based workbench.
SESSION_NAME=speech-workbench
VOICE_AUTO_TMUX_SESSION=speech-workbench
AUTO_STT_MODE=pane
AUTO_LOG="${XDG_RUNTIME_DIR:-/tmp}/speech-agent-workbench-auto.log"
AUTO_CONSOLE_LOG="${XDG_RUNTIME_DIR:-/tmp}/speech-agent-workbench-console.log"
